# Example — DO NOT commit the real version of this file.
# Create the actual secret with:
#   kubectl create secret generic bpp-backend-secrets \
#     --namespace=bro-please-pay \
#     --from-literal=SUPABASE_URL=https://xxx.supabase.co \
#     --from-literal=SUPABASE_ANON_KEY=eyJ... \
#     --from-literal=SUPABASE_SERVICE_ROLE_KEY=eyJ... \
#     --from-literal=SUPABASE_JWT_SECRET=your-jwt-secret \
#     --from-literal=GEMINI_API_KEY=AIza... \
#     --from-literal=FRONTEND_URL=https://bro-please-pay.vercel.app

apiVersion: v1
kind: Secret
metadata:
  name: bpp-backend-secrets
  namespace: bro-please-pay
type: Opaque
stringData:
  SUPABASE_URL: "https://xxx.supabase.co"
  SUPABASE_ANON_KEY: "your-anon-key"
  SUPABASE_SERVICE_ROLE_KEY: "your-service-role-key"
  SUPABASE_JWT_SECRET: "your-jwt-secret"
  GEMINI_API_KEY: "your-gemini-key"
  FRONTEND_URL: "https://bro-please-pay.vercel.app"
